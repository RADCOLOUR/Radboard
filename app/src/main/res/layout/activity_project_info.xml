<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical"
        android:background="@color/background">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_button_press"
            android:src="@drawable/ic_back"
            android:scaleType="center"
            android:contentDescription="@string/btn_back"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@drawable/bg_section_header_green"
            android:paddingStart="12dp"
            android:gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tvProjectName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/positive"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_button_press"
            android:backgroundTint="@color/surface_variant"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/btn_edit"
            android:textColor="@color/positive"
            android:textSize="9sp"
            android:stateListAnimator="@null"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/outline"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Time Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_gradient_green"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_section_header_green"
                    android:paddingStart="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/info_section_time"
                        android:textColor="@color/positive"
                        android:textSize="9sp"
                        android:letterSpacing="0.15"
                        android:textAllCaps="true"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvTimeSpent"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/positive"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02"/>

                    <Button
                        android:id="@+id/btnTimerToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_button_press"
                        android:backgroundTint="@color/surface_variant"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="@string/btn_start"
                        android:textColor="@color/positive"
                        android:textSize="11sp"
                        android:stateListAnimator="@null"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Details Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_gradient_green"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_section_header_green"
                    android:paddingStart="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/info_section_details"
                        android:textColor="@color/positive"
                        android:textSize="9sp"
                        android:letterSpacing="0.15"
                        android:textAllCaps="true"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvCreated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvKey"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_background"
                        android:textSize="11sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvScale"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_background"
                        android:textSize="11sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvBpm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_background"
                        android:textSize="11sp"
                        android:layout_marginBottom="8dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Description Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_gradient_green">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_section_header_green"
                    android:paddingStart="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/info_section_description"
                        android:textColor="@color/positive"
                        android:textSize="9sp"
                        android:letterSpacing="0.15"
                        android:textAllCaps="true"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp"
                    android:padding="16dp"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>