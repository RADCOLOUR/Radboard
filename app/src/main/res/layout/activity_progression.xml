<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical"
        android:background="@color/background">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_button_press"
            android:src="@drawable/ic_back"
            android:scaleType="center"
            android:contentDescription="@string/btn_back"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@drawable/bg_section_header_pink"
            android:paddingStart="12dp"
            android:gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tvSongTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/progression_title"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnTranspose"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_button_press"
            android:backgroundTint="@color/secondary_container"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:stateListAnimator="@null"
            android:text="@string/btn_transpose"
            android:textColor="@color/secondary"
            android:textSize="9sp" />

        <Button
            android:id="@+id/btnAddSection"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_button_press"
            android:backgroundTint="@color/primary_container"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/btn_add_section"
            android:textColor="@color/primary"
            android:textSize="9sp"
            android:stateListAnimator="@null"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/outline"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/sectionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"/>

    </ScrollView>

</LinearLayout>