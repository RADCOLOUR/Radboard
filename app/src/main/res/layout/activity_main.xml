<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical"
            android:background="@color/background">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_button_press"
                android:src="@drawable/ic_menu"
                android:scaleType="center"
                android:contentDescription="@string/btn_menu"/>

            <TextView
                android:id="@+id/tvBranding"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/branding"
                android:textColor="@color/on_background"
                android:textSize="15sp"
                android:letterSpacing="0.05"
                android:textStyle="bold"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvClock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_timer"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp"
                android:letterSpacing="0.02"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/outline"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:padding="12dp"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card_gradient_pink"
                android:padding="16dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/session_label"
                    android:textColor="@color/primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:textAllCaps="true"
                    android:gravity="center"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvSessionTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_timer"
                    android:textColor="@color/primary"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <Button
                        android:id="@+id/btnSessionStart"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/btn_start"
                        android:textColor="@color/on_primary"
                        android:background="@drawable/bg_button_primary_press"
                        android:textSize="11sp"
                        android:stateListAnimator="@null"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"/>

                    <Button
                        android:id="@+id/btnSessionReset"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/btn_reset"
                        android:textColor="@color/primary"
                        android:background="@drawable/bg_button_press"
                        android:backgroundTint="@color/surface_variant"
                        android:textSize="11sp"
                        android:stateListAnimator="@null"
                        android:layout_marginStart="8dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"/>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card_gradient_yellow"
                android:padding="16dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/bpm_label"
                    android:textColor="@color/secondary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:textAllCaps="true"
                    android:gravity="center"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvBpm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_bpm"
                    android:textColor="@color/secondary"
                    android:textSize="52sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"/>

                <Button
                    android:id="@+id/btnTap"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:text="@string/btn_tap"
                    android:textColor="@color/on_secondary"
                    android:background="@drawable/bg_button_secondary_press"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:stateListAnimator="@null"
                    android:layout_marginTop="12dp"/>

                <Button
                    android:id="@+id/btnBpmReset"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/btn_reset"
                    android:textColor="@color/secondary"
                    android:background="@drawable/bg_button_press"
                    android:backgroundTint="@color/surface_variant"
                    android:textSize="11sp"
                    android:stateListAnimator="@null"
                    android:layout_marginTop="8dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="220dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@drawable/bg_card_glass"
        android:orientation="vertical"
        android:paddingTop="40dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/branding"
            android:textColor="@color/on_background"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/outline"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/btnChords"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_button_glass"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_chords"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_chords"
                android:textColor="@color/positive"
                android:textSize="12sp"
                android:letterSpacing="0.01"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNotepad"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_button_glass"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_notepad"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_notepad"
                android:textColor="@color/tertiary"
                android:textSize="12sp"
                android:letterSpacing="0.01"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnProgressions"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_button_glass"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_progression"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_progressions"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:letterSpacing="0.01"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/outline"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_button_glass"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_settings"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_title"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:letterSpacing="0.01"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/outline"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_version"
            android:textColor="@color/on_surface_variant"
            android:textSize="9sp"
            android:paddingStart="20dp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>