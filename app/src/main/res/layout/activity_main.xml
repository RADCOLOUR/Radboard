<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:orientation="vertical">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical"
            android:background="@color/background">

            <Button
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_button"
                android:backgroundTint="@color/background"
                android:text="☰"
                android:textColor="@color/on_background"
                android:textSize="18sp"
                android:padding="0dp"
                android:stateListAnimator="@null"/>

            <TextView
                android:id="@+id/tvBranding"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/branding"
                android:textColor="@color/on_background"
                android:textSize="15sp"
                android:letterSpacing="0.05"
                android:textStyle="bold"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvClock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_timer"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp"
                android:letterSpacing="0.02"/>

        </LinearLayout>

        <!-- Outline divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/outline"/>

        <!-- Main Panels -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:padding="12dp"
            android:weightSum="2">

            <!-- Session Timer Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/session_label"
                    android:textColor="@color/primary"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:textAllCaps="true"/>

                <TextView
                    android:id="@+id/tvSessionTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_timer"
                    android:textColor="@color/primary"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:layout_marginTop="4dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <Button
                        android:id="@+id/btnSessionStart"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/btn_start"
                        android:textColor="@color/on_primary"
                        android:backgroundTint="@color/primary"
                        android:textSize="11sp"
                        android:stateListAnimator="@null"
                        android:background="@drawable/bg_button"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"/>

                    <Button
                        android:id="@+id/btnSessionReset"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/btn_reset"
                        android:textColor="@color/primary"
                        android:backgroundTint="@color/surface_variant"
                        android:textSize="11sp"
                        android:stateListAnimator="@null"
                        android:background="@drawable/bg_button"
                        android:layout_marginStart="8dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- BPM Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bpm_label"
                    android:textColor="@color/secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:textAllCaps="true"/>

                <TextView
                    android:id="@+id/tvBpm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_bpm"
                    android:textColor="@color/secondary"
                    android:textSize="52sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:layout_marginTop="4dp"/>

                <Button
                    android:id="@+id/btnTap"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:text="@string/btn_tap"
                    android:textColor="@color/on_secondary"
                    android:backgroundTint="@color/secondary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:stateListAnimator="@null"
                    android:background="@drawable/bg_button"
                    android:layout_marginTop="12dp"/>

                <Button
                    android:id="@+id/btnBpmReset"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/btn_reset"
                    android:textColor="@color/secondary"
                    android:backgroundTint="@color/surface_variant"
                    android:textSize="11sp"
                    android:stateListAnimator="@null"
                    android:background="@drawable/bg_button"
                    android:layout_marginTop="8dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Sidebar -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="220dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/surface"
        android:orientation="vertical"
        android:paddingTop="40dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/branding"
            android:textColor="@color/on_background"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/outline"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnChords"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_chords"
            android:textColor="@color/positive"
            android:backgroundTint="@color/surface"
            android:textSize="12sp"
            android:gravity="start|center_vertical"
            android:paddingStart="20dp"
            android:letterSpacing="0.01"
            android:stateListAnimator="@null"
            android:background="@drawable/bg_button"/>

        <Button
            android:id="@+id/btnNotepad"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="NOTEPAD"
            android:textColor="@color/tertiary"
            android:backgroundTint="@color/surface"
            android:textSize="12sp"
            android:gravity="start|center_vertical"
            android:paddingStart="20dp"
            android:letterSpacing="0.01"
            android:stateListAnimator="@null"
            android:background="@drawable/bg_button"/>

        <Button
            android:id="@+id/btnProgressions"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="CHORD PROGRESSIONS"
            android:textColor="@color/primary"
            android:backgroundTint="@color/surface"
            android:textSize="12sp"
            android:gravity="start|center_vertical"
            android:paddingStart="20dp"
            android:letterSpacing="0.01"
            android:stateListAnimator="@null"
            android:background="@drawable/bg_button"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/outline"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/outline"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/settings_title"
            android:textColor="@color/on_surface_variant"
            android:backgroundTint="@color/surface"
            android:textSize="12sp"
            android:gravity="start|center_vertical"
            android:paddingStart="20dp"
            android:letterSpacing="0.01"
            android:stateListAnimator="@null"
            android:background="@drawable/bg_button"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Radboard v1.0.2"
            android:textColor="@color/on_surface_variant"
            android:textSize="9sp"
            android:paddingStart="20dp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>